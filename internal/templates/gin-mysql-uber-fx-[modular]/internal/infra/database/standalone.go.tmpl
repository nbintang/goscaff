package database

import (
	"fmt"

	"{{.MODULE_PATH}}/config"

	"gorm.io/driver/mysql"
	"gorm.io/gorm"
)

func GetStandalone(env config.Env, logger *DBLogger) (*gorm.DB, error) {
	dsn := fmt.Sprintf(
		"%s:%s@tcp(%s:%d)/%s?parseTime=true&loc=Local",
		env.DatabaseUser,
		env.DatabasePassword,
		env.DatabaseHost,
		env.DatabasePort,
		env.DatabaseName,
	)

	return gorm.Open(mysql.Open(dsn), &gorm.Config{
		Logger: logger,
	})
}
