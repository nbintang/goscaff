package repositories

import (
	"context"
	"errors"
	"{{.MODULE_PATH}}/internal/entities"
	"{{.MODULE_PATH}}/internal/enums"

	"gorm.io/gorm"
)

type userRepositoryImpl struct {
	db *gorm.DB
}

func NewUserRepository(db *gorm.DB) UserRepository {
	return &userRepositoryImpl{db}
}

func (r *userRepositoryImpl) FindAll(ctx context.Context, limit, offset int) ([]entities.User, int64, error) {
	var users []entities.User
	var total int64
	var user entities.User
	db := r.db.WithContext(ctx).Model(&user)
	if err := db.Count(&total).Error; err != nil {
		return nil, 0, err
	}

	if err := db.Scopes(PaginateUser(limit, offset)).Find(&users).Error; err != nil {
		return nil, 0, err
	}

	return users, total, nil
}

func (r *userRepositoryImpl) FindByID(ctx context.Context, id string) (*entities.User, error) {
	var user entities.User
	if err := r.db.WithContext(ctx).Scopes(WhereUserID(id), SelectedUserFields()).Take(&user).Error; err != nil {
		if errors.Is(err, gorm.ErrRecordNotFound) {
			return nil, nil
		}
		return nil, err
	}
	return &user, nil
}

func (r *userRepositoryImpl) FindByIDWithRole(ctx context.Context, id string) (*entities.User, error) {
	var user entities.User
	if err := r.db.WithContext(ctx).Scopes(WhereUserID(id), SelectedUserFields("role")).Take(&user).Error; err != nil {
		if errors.Is(err, gorm.ErrRecordNotFound) {
			return nil, nil
		}
		return nil, err
	}
	return &user, nil
}

func (r *userRepositoryImpl) FindByEmail(ctx context.Context, email string) (*entities.User, error) {
	var user entities.User
	if err := r.db.WithContext(ctx).Scopes(WhereUserEmail(email), SelectedUserFields("role")).Take(&user).Error; err != nil {
		if errors.Is(err, gorm.ErrRecordNotFound) {
			return nil, nil
		}
		return nil, err
	}
	return &user, nil
}

func (r *userRepositoryImpl) FindExistsByEmail(ctx context.Context, email string) (bool, error) {
	var count int64
	var user entities.User
	var db = r.db.WithContext(ctx).Model(&user)
	err := db.Scopes(WhereUserEmail(email)).Count(&count).Error
	return count > 0, err
}

func (r *userRepositoryImpl) Update(ctx context.Context, id string, user *entities.User) error {
	if err := r.db.WithContext(ctx).Scopes(WhereUserID(id)).Updates(&user).Error; err != nil {
		return err
	}
	return nil
}

func (r *userRepositoryImpl) Create(ctx context.Context, user *entities.User) error {
	user.Role = entities.Role(enums.USER)
	err := r.db.WithContext(ctx).Create(&user).Error
	return err
}
